{
  "rules": {
    "distress": {
      ".read": "auth != null",
      ".indexOn": ["g"],
      "$uid": {
        ".write": "auth != null && auth.uid == $uid",
        ".validate": "newData.child('active').val() == false || (newData.child('active').val() == true && newData.child('l').exists() && newData.child('g').exists() && newData.child('alias').isString())"
      }
    },
    "patrols": {
      ".read": "auth != null",
      ".indexOn": ["g"],
      "$uid": {
        ".write": "auth != null && auth.uid == $uid",
        ".validate": "newData.child('active').val() == false || (newData.child('active').val() == true && newData.child('l').exists() && newData.child('g').exists())"
      }
    },
    "distress_history": {
      ".read": "auth != null",
      "$entryId": {
        ".write": "auth != null && newData.child('personData').child('id').val() == auth.uid"
      }
    },
    "intervening": {
      ".read": "auth != null",
      "$distressId": {
        "$vigilanteUid": {
          ".write": "auth != null && auth.uid == $vigilanteUid",
          ".validate": "newData.child('personId').val() == $distressId && newData.child('timestamp').isNumber()"
        }
      }
    },
    "chat_presence": {
      ".read": "auth != null",
      ".indexOn": ["g"],
      "$uid": {
        ".write": "auth != null && auth.uid == $uid",
        ".validate": "newData.child('active').val() == false || (newData.child('active').val() == true && newData.child('l').exists() && newData.child('g').exists() && newData.child('alias').isString())"
      }
    },
    "chat_user_rooms": {
      ".read": "auth != null",
      "$uid": {
        "$roomId": {
          ".write": "auth != null"
        }
      }
    },
    "chat_rooms": {
      ".read": "auth != null",
      "$roomId": {
        ".write": "auth != null"
      }
    },
    "chat_messages": {
      "$roomId": {
        ".read": "auth != null",
        "$messageId": {
          ".write": "auth != null && newData.child('senderId').val() == auth.uid",
          ".validate": "newData.child('text').isString() && newData.child('timestamp').isNumber()"
        }
      }
    }
  }
}
