<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivChatRoomBell"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="6dp"
            android:contentDescription="@string/chat_ringing_label"
            android:src="@drawable/ic_bell"
            android:visibility="gone"
            app:tint="?attr/colorPrimary"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tvChatRoomTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Alex" />

        <ImageButton
            android:id="@+id/btnDeleteChatRoom"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/chat_remove_title"
            android:src="@drawable/ic_delete"
            app:tint="?android:attr/textColorSecondary" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvChatRoomSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="13sp"
        tools:text="Direct · 14:32" />
</LinearLayout>
